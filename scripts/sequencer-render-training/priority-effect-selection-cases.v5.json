{
  "version": "5.0",
  "description": "Cross-effect selector evaluation expanded to include SingleStrand against the current merged selector set.",
  "cases": [
    {
      "caseId": "select_twinkle_restrained_line",
      "description": "Restrained steady animated texture on a line should prefer Twinkle over motion-centric effects.",
      "requiredIntents": ["animated", "patterned", "restrained", "steady"],
      "requiredPatternFamilies": ["linear_restrained_twinkle"],
      "geometryProfiles": ["single_line_horizontal"],
      "effects": ["Bars", "Marquee", "Twinkle"],
      "expectedSelection": "Twinkle"
    },
    {
      "caseId": "select_twinkle_strobe_spinner",
      "description": "Bold busy animated radial texture on the spinner should prefer Twinkle over Shockwave.",
      "requiredIntents": ["animated", "bold", "busy", "patterned"],
      "requiredPatternFamilies": ["radial_strobe_twinkle"],
      "geometryProfiles": ["spinner_standard"],
      "effects": ["Twinkle", "Shockwave"],
      "expectedSelection": "Twinkle"
    },
    {
      "caseId": "select_shockwave_fill_spinner",
      "description": "Centered fill-oriented radial motion on the spinner should prefer Shockwave.",
      "requiredIntents": ["animated", "fill", "patterned"],
      "requiredPatternFamilies": ["radial_diffuse_shockwave"],
      "geometryProfiles": ["spinner_standard"],
      "effects": ["Twinkle", "Shockwave"],
      "expectedSelection": "Shockwave"
    },
    {
      "caseId": "select_twinkle_varied_spinner",
      "description": "Varied restrained radial texture should prefer Twinkle.",
      "requiredIntents": ["animated", "patterned", "restrained", "varied"],
      "requiredPatternFamilies": ["radial_classic_random_twinkle"],
      "geometryProfiles": ["spinner_standard"],
      "effects": ["Twinkle", "Shockwave", "Pinwheel"],
      "expectedSelection": "Twinkle"
    },
    {
      "caseId": "select_shockwave_crisp_spinner",
      "description": "Crisp radial motion on the spinner should prefer Shockwave over Twinkle.",
      "requiredIntents": ["animated", "fill", "patterned"],
      "requiredPatternFamilies": ["radial_crisp_shockwave"],
      "geometryProfiles": ["spinner_standard"],
      "effects": ["Twinkle", "Shockwave"],
      "expectedSelection": "Shockwave"
    },
    {
      "caseId": "select_shockwave_helical_compact",
      "description": "Geometry-coupled compact helical ring motion should prefer Shockwave on spiral trees.",
      "requiredIntents": ["animated", "geometry_coupled", "patterned", "restrained"],
      "requiredPatternFamilies": ["helical_compact_shockwave"],
      "geometryProfiles": ["tree_360_spiral"],
      "effects": ["Shockwave", "Spirals", "Twinkle", "Pinwheel"],
      "expectedSelection": "Shockwave"
    },
    {
      "caseId": "select_singlestrand_bounce_vertical",
      "description": "Bounce-driven vertical line motion should prefer SingleStrand over Bars and Marquee.",
      "requiredIntents": ["animated", "restrained"],
      "requiredPatternFamilies": ["bounce"],
      "geometryProfiles": ["single_line_vertical"],
      "effects": ["SingleStrand", "Bars", "Marquee"],
      "expectedSelection": "SingleStrand"
    },
    {
      "caseId": "select_singlestrand_directional_arch",
      "description": "Directional restrained chase on grouped arches should prefer SingleStrand over Bars and Marquee.",
      "requiredIntents": ["animated", "directional", "restrained"],
      "requiredPatternFamilies": ["directional_chase"],
      "geometryProfiles": ["arch_grouped"],
      "effects": ["SingleStrand", "Bars", "Marquee"],
      "expectedSelection": "SingleStrand"
    },
    {
      "caseId": "select_singlestrand_tree_travel",
      "description": "Restrained animated travel on flat trees should prefer SingleStrand over Spirals and Twinkle.",
      "requiredIntents": ["animated", "restrained"],
      "requiredPatternFamilies": ["spiral_travel"],
      "geometryProfiles": ["tree_flat_single_layer"],
      "effects": ["SingleStrand", "Spirals", "Twinkle"],
      "expectedSelection": "SingleStrand"
    }
  ]
}
