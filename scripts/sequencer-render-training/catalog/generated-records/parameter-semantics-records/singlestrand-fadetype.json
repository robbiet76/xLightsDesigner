    "controlType": "choice",
    "default": "None",
    "min": null,
    "max": null,
    "options": [
      "None",
      "From Head",
      "From Tail",
      "Head and Tail",
      "Middle"
    ],
    "valueCurve": false,
    "lockable": true,
    "suppressIfDefault": false
  },
