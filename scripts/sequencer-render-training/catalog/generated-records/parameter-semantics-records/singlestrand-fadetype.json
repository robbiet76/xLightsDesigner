  "sourceDefinition": {
    "id": "Fade_Type",
    "label": "Fade",
    "description": "Applies a brightness fade to the chase segment. 'From Head' fades from the leading edge, 'From Tail' from the trailing edge, 'Head and Tail' fades both ends, and 'Middle' fades from the center outward.",
