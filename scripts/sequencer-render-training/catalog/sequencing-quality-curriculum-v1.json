      "covered",
      "retired"
    ]
  },
  "areas": [
    {
      "areaId": "core_render_validity",
      "priority": 1,
      "purpose": "Prove effects can render, produce visible output, and expose useful setting regions before relying on them creatively."
    },
    {
      "areaId": "effect_behavior",
      "priority": 2,
      "purpose": "Learn each effect's visible behavior, palette handling, model fit, and high-impact parameters."
    },
    {
      "areaId": "model_geometry_fit",
      "priority": 3,
      "purpose": "Learn which effects read well across built-in, imported, and custom model structures."
    },
    {
      "areaId": "layer_composition",
      "priority": 4,
      "purpose": "Learn how same-target layers, group/member layers, order, blend, brightness, contrast, fade, and timing overlap affect display readability."
    },
    {
      "areaId": "submodel_behavior",
      "priority": 5,
      "purpose": "Learn parent versus submodel targeting and sibling submodel behavior through the same framework for every model type."
    },
    {
      "areaId": "display_level_composition",
      "priority": 6,
      "purpose": "Learn whole-display coverage, balance, foreground/background separation, regional variety, and visual readability."
    },
    {
      "areaId": "musical_structure",
      "priority": 7,
      "purpose": "Learn section energy, phrase/beat alignment, repetition with variation, and lyric/accent timing behavior."
    },
    {
      "areaId": "creative_intent_matching",
      "priority": 8,
      "purpose": "Learn whether generated sequences match user intent for mood, palette, pace, emphasis, and creative accuracy."
    }
  ],
