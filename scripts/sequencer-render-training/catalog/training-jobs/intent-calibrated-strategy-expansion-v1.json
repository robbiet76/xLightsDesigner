    "maxRepeatedGoalSelectionRequiresIntervention": true
  },
  "curriculumScope": {
    "trainingLayout": "render-training-vendor-fixture",
    "primaryEvidence": "full_sequence_render",
    "currentFocus": [
      "explicit design-intent fit",
      "quality-consistency repair",
      "focal-handoff repair",
      "temporal-continuity guardrails",
      "palette-purpose preservation",
      "bounded style variation"
    ],
    "targetGoalIds": [
      "display.video_aesthetic.palette_foundation_guarded_revalidation_v1",
      "display.video_aesthetic.palette_focal_handoff_guarded_context_sequence_v1",
      "display.video_aesthetic.palette_foundation_soft_counterpoint_v1",
      "display.video_aesthetic.palette_foundation_calibrated_counterpoint_v1",
      "display.video_aesthetic.palette_transition_motion_bridge_v1"
