{
  "artifactType": "sequencing_quality_training_job_v1",
  "artifactVersion": 1,
  "jobId": "intent-calibrated-strategy-expansion-v1",
  "chunkId": "vendor-fixture-intent-calibrated-strategy-expansion",
  "status": "active",
  "description": "Run bounded full-sequence strategy expansion after auto-refill validation stalls. This job prioritizes explicit design intent, hard quality guardrails, focal handoff, temporal continuity, palette purpose, and guarded style variation instead of near-duplicate baseline comparisons.",
  "defaults": {
