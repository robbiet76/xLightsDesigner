  "operatorReviewPolicy": {
    "requiredOnlyWhen": [
      "max_consecutive_regressions",
      "max_repeated_goal_selection",
      "blocked_no_controller_queue_without_chunk_completion",
      "awaiting_evidence",
      "new human rubric labels are explicitly requested"
    ],
    "preferredReviewSurface": "xLightsDesigner Review page"
  }
