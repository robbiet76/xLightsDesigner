    "Twinkle": {
      "complexityClass": "complex",
      "earlySamplingPolicy": "broad_geometry_first",
      "notes": "Higher-value texture effect than Shimmer for long-term training. Density, dwell, strobe behavior, rerandomization, and render method should be screened first.",
      "parameters": {
        "style": {
          "type": "enum",
          "anchors": ["Old Render Method", "New Render Method"],
          "importance": "high",
          "phase": "baseline",
          "practicalPriority": "high",
          "interactionHypotheses": ["count", "steps", "strobe"],
          "stopRule": "all_meaningful_options"
        },
        "count": {
          "type": "numeric",
          "range": {
            "min": 1,
            "max": 10
          },
          "anchors": [1, 3, 5, 7, 9],
          "importance": "high",
          "phase": "screen",
          "practicalPriority": "high",
          "interactionHypotheses": ["steps", "strobe", "geometryProfile"],
          "stopRule": "stop_when_regions_stabilize"
        },
        "steps": {
          "type": "numeric",
          "range": {
            "min": 1,
            "max": 100
          },
          "anchors": [10, 30, 50, 70, 90],
          "importance": "high",
          "phase": "screen",
          "practicalPriority": "high",
          "interactionHypotheses": ["count", "strobe", "style"],
          "stopRule": "refine_only_near_breakpoints"
        },
        "strobe": {
          "type": "boolean",
          "anchors": [false, true],
          "importance": "high",
          "phase": "screen",
          "practicalPriority": "high",
          "interactionHypotheses": ["steps", "style"],
          "stopRule": "all_meaningful_options"
        },
        "reRandomize": {
          "type": "boolean",
          "anchors": [false, true],
          "importance": "medium",
          "phase": "screen",
          "practicalPriority": "medium",
          "interactionHypotheses": ["style", "count"],
          "stopRule": "all_meaningful_options"
        }
      }
    },
    "Color Wash": {
      "notes": "Structure often changes more from boolean fade combinations than from numeric cycle changes.",
      "parameters": {
        "cycles": {
          "type": "numeric",
          "range": {
            "min": 0.5,
