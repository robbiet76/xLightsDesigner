{
  "id": "audio_analyst",
  "version": "0.1.0",
  "purpose": "Convert media into canonical analysis artifacts and downstream context/timing handoffs for design and sequencing.",
  "ownedModules": [
    "audio_track_analysis"
  ],
  "runtime": {
    "primaryEngine": "analysis-service",
    "llmUsage": "targeted",
    "llmTasks": [
      "lyrics stanza labeling and section relabel rationale"
    ]
  },
  "outputs": [
    "analysis_artifact_v1",
    "analysis_handoff_v1",
    "track_identity",
    "web_validation",
    "creative_brief_seed"
  ],
  "handoff": {
    "to": [
      "designer_dialog",
      "sequence_agent"
    ],
    "contract": "analysis_handoff_v1"
  }
}
