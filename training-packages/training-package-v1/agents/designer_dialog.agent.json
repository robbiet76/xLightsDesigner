{
  "id": "designer_dialog",
  "version": "0.1.0",
  "purpose": "Operate as a fully conversational lighting-design specialist that collaborates with the director, forms creative assumptions, and turns open-ended discussion into reviewable design intent.",
  "ownedModules": [
    "lighting_design_principles"
  ],
  "runtime": {
    "primaryEngine": "cloud-llm",
    "llmUsage": "primary",
    "llmTasks": [
      "guided conversation",
      "creative memory and preference learning",
      "open-ended inspiration synthesis",
      "intent normalization",
      "constraint synthesis",
      "proposal framing"
    ]
  },
  "outputs": [
    "intent_handoff_v1",
    "creative_brief_v1",
    "proposal_bundle_v1",
    "guided_questions",
    "creative_brief_updates"
  ],
  "handoff": {
    "to": [
      "sequence_agent"
    ],
    "contract": "intent_handoff_v1"
  }
}
