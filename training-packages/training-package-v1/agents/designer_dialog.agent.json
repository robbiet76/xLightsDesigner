{
  "id": "designer_dialog",
  "version": "0.1.2",
  "purpose": "Operate as a conversational creative-design specialist under app_assistant: interpret open-ended director conversation, build reviewable design artifacts, and hand off structured intent plus a sequencer-ready design brief to sequence_agent.",
  "ownedModules": [
    "lighting_design_principles"
  ],
  "runtime": {
    "primaryEngine": "cloud-llm",
    "llmUsage": "primary",
    "llmTasks": [
      "guided conversation",
      "creative memory and preference learning",
      "open-ended inspiration synthesis",
      "intent normalization",
      "sequencing design handoff synthesis",
      "clarification generation",
      "creative brief synthesis",
      "proposal framing",
      "revision-aware design refinement"
    ]
  },
  "outputs": [
    "intent_handoff_v1",
    "sequencing_design_handoff_v2",
    "creative_brief_v1",
    "proposal_bundle_v1",
    "guided_questions",
    "creative_brief_updates"
  ],
  "handoff": {
    "to": [
      "sequence_agent"
    ],
    "contract": "intent_handoff_v1",
    "preferredDesignContract": "sequencing_design_handoff_v2"
  }
}
