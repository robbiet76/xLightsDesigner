{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "design_scene_context_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "createdAt",
    "artifactType",
    "artifactVersion"
  ],
  "properties": {
    "artifactType": {
      "const": "design_scene_context_v1"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "artifactVersion": {
      "const": "1.0"
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "layoutRevision": {
      "type": "string"
    },
    "spatialZones": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "focalCandidates": {
      "type": "array",
      "items": { "type": "string" }
    },
    "coverageDomains": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}
