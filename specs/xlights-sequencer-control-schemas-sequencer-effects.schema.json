{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xlightsdesigner.local/specs/xlights-sequencer-control/sequencer-effects.schema.json",
  "title": "xLights v2 Sequencer and Effects Params",
  "type": "object",
  "required": [
    "cmd",
    "params"
  ],
  "properties": {
    "cmd": {
      "type": "string",
      "enum": [
        "sequencer.getDisplayElementOrder",
        "sequencer.setDisplayElementOrder",
        "sequencer.setActiveDisplayElements",
        "effects.list",
        "effects.getPalette",
        "effects.getRenderStyleOptions",
        "effects.setPalette",
        "effects.setRenderStyle",
        "effects.create",
        "effects.update",
        "effects.delete",
        "effects.deleteLayer",
        "effects.compactLayers",
        "effects.shift",
        "effects.alignToTiming",
        "effects.clone"
      ]
    },
    "params": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "cmd": {
            "const": "sequencer.setActiveDisplayElements"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "required": [
              "activeIds"
            ],
            "properties": {
              "activeIds": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "preserveRelativeOrder": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cmd": {
            "const": "effects.deleteLayer"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "required": [
              "modelName",
              "layerIndex"
            ],
            "properties": {
              "modelName": {
                "type": "string",
                "minLength": 1
              },
              "layerIndex": {
                "type": "integer",
                "minimum": 0
              },
              "force": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cmd": {
            "const": "effects.compactLayers"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "required": [
              "modelName"
            ],
            "properties": {
              "modelName": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cmd": {
            "const": "sequencer.setDisplayElementOrder"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "required": [
              "orderedIds"
            ],
            "properties": {
              "orderedIds": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": [
                    "string",
                    "integer"
                  ]
                }
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cmd": {
            "const": "effects.create"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "required": [
              "modelName",
              "layerIndex",
              "effectName",
              "startMs",
              "endMs"
            ],
            "properties": {
              "modelName": {
                "type": "string",
                "minLength": 1
              },
              "layerIndex": {
                "type": "integer",
                "minimum": 0
              },
              "effectName": {
                "type": "string",
                "minLength": 1
              },
              "startMs": {
                "type": "integer",
                "minimum": 0
              },
              "endMs": {
                "type": "integer",
                "minimum": 1
              },
              "settings": {
                "type": "object"
              },
              "palette": {
                "type": "object"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cmd": {
            "enum": [
              "effects.update",
              "effects.delete",
              "effects.shift",
              "effects.alignToTiming",
              "effects.clone"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "properties": {
              "effectId": {
                "type": [
                  "string",
                  "integer"
                ]
              },
              "effectIds": {
                "type": "array",
                "items": {
                  "type": [
                    "string",
                    "integer"
                  ]
                }
              },
              "modelName": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "layerIndex": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0
              },
              "startMs": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "endMs": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "deltaMs": {
                "type": "integer"
              },
              "timingTrackName": {
                "type": "string",
                "minLength": 1
              },
              "mode": {
                "type": "string"
              },
              "sourceModelName": {
                "type": "string"
              },
              "sourceLayerIndex": {
                "type": "integer",
                "minimum": 0
              },
              "targetModels": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "targetLayerIndex": {
                "type": "integer",
                "minimum": 0
              },
              "clipToSequence": {
                "type": "boolean"
              },
              "settings": {
                "type": "object"
              },
              "palette": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cmd": {
            "const": "effects.getPalette"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "required": [
              "effectId"
            ],
            "properties": {
              "effectId": {
                "type": [
                  "string",
                  "integer"
                ]
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cmd": {
            "const": "effects.setPalette"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "required": [
              "effectId",
              "palette"
            ],
            "properties": {
              "effectId": {
                "type": [
                  "string",
                  "integer"
                ]
              },
              "palette": {
                "type": "object"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cmd": {
            "const": "effects.getRenderStyleOptions"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "required": [
              "modelName"
            ],
            "properties": {
              "modelName": {
                "type": "string",
                "minLength": 1
              },
              "layerIndex": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cmd": {
            "const": "effects.setRenderStyle"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "required": [
              "effectId",
              "renderStyle"
            ],
            "properties": {
              "effectId": {
                "type": [
                  "string",
                  "integer"
                ]
              },
              "renderStyle": {
                "type": "string",
                "minLength": 1
              },
              "camera": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "transform": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "bufferStagger": {
                "type": "integer"
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
