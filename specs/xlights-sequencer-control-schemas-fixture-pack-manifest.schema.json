{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xlightsdesigner.local/specs/xlights-sequencer-control/fixture-pack-manifest.schema.json",
  "title": "xLights Control Fixture Pack Manifest",
  "type": "object",
  "required": [
    "version",
    "description",
    "fixturePack",
    "environment",
    "suites",
    "aggregateExpectedOutput"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "fixturePack": {
      "type": "object",
      "required": [
        "packId",
        "packVersion",
        "source",
        "assets"
      ],
      "properties": {
        "packId": {
          "type": "string",
          "minLength": 1
        },
        "packVersion": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "object",
          "required": [
            "type",
            "uri"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "local",
                "remote"
              ]
            },
            "uri": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "assets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "type",
              "envVar",
              "required",
              "checksum"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "enum": [
                  "sequence",
                  "media",
                  "timing",
                  "model"
                ]
              },
              "envVar": {
                "type": "string",
                "pattern": "^[A-Z0-9_]+$"
              },
              "required": {
                "type": "boolean"
              },
              "pathHint": {
                "type": "string"
              },
              "checksum": {
                "type": "object",
                "required": [
                  "algo",
                  "value"
                ],
                "properties": {
                  "algo": {
                    "type": "string",
                    "enum": [
                      "sha256"
                    ]
                  },
                  "value": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
