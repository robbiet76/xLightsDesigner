{
  "name": "xlightsdesigner-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "main.mjs",
  "scripts": {
    "dev": "node scripts/retired-command.mjs dev",
    "start": "node scripts/retired-command.mjs start",
    "test:agent-ui": "node --test ../xlightsdesigner-ui/tests/agent/*.test.js ../xlightsdesigner-ui/tests/agent/audio-analyst/*.test.js ../xlightsdesigner-ui/tests/agent/designer-dialog/*.test.js ../xlightsdesigner-ui/tests/agent/sequence-agent/*.test.js",
    "prepare:renderer": "node scripts/retired-command.mjs prepare:renderer",
    "dist:dir": "node scripts/retired-command.mjs dist:dir",
    "dist:mac": "node scripts/retired-command.mjs dist:mac",
    "install:mac-app": "node scripts/retired-command.mjs install:mac-app",
    "install:launch-agent": "node scripts/retired-command.mjs install:launch-agent",
    "verify:bundle": "node scripts/retired-command.mjs verify:bundle"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "org.xlightsdesigner.desktop",
    "productName": "xLightsDesigner",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.mjs",
      "live-validation-suites.mjs",
      "automation-request-processor.mjs",
      "preload.mjs",
      "xlights-validation.mjs",
      "designer-chat-sanitizer.mjs",
      "renderer/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": false
    }
  }
}
