{
  "name": "xlightsdesigner-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "main.mjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "test:agent-ui": "node --test ../xlightsdesigner-ui/tests/agent/*.test.js ../xlightsdesigner-ui/tests/agent/audio-analyst/*.test.js ../xlightsdesigner-ui/tests/agent/designer-dialog/*.test.js ../xlightsdesigner-ui/tests/agent/sequence-agent/*.test.js",
    "prepare:renderer": "node scripts/prepare-renderer.mjs",
    "dist:dir": "npm run prepare:renderer && electron-builder --dir",
    "dist:mac": "npm run prepare:renderer && electron-builder --mac zip && node scripts/install-mac-app.mjs",
    "install:mac-app": "node scripts/install-mac-app.mjs",
    "verify:bundle": "node scripts/verify-bundle.mjs"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "org.xlightsdesigner.desktop",
    "productName": "xLightsDesigner",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.mjs",
      "preload.mjs",
      "designer-chat-sanitizer.mjs",
      "analysis-artifact-store.mjs",
      "project-artifact-store.mjs",
      "renderer/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": false
    }
  }
}
